{
    "omnisharp.analyzeOpenDocumentsOnly": true,
    "dotnet.defaultSolution": "SpaceStation14.sln",
    "json.schemas": [
        {
            "fileMatch": [ "**/meta.json" ],
            "url": "https://raw.githubusercontent.com/Simple-Station/Einstein-Engines/master/.github/rsi-schema.json"
        }
    ],
    "chat.tools.terminal.autoApprove": {
        "/^cd /h/nuclear-14-PR/nuclear-14 && node -e \"\nconst fs = require\\('fs'\\);\nconst path = 'Resources/ServerInfo/_Misfits/ServerRules/DefaultRuleset\\.xml';\nlet c = fs\\.readFileSync\\(path, 'utf8'\\);\nconst count = \\(c\\.match\\(/\\[ \\\\t\\]\\*<!--\\[\\\\s\\\\S\\]\\*\\?-->\\[ \\\\t\\]\\*/g\\) \\|\\| \\[\\]\\)\\.length;\nc = c\\.replace\\(/\\[ \\\\t\\]\\*<!--\\[\\\\s\\\\S\\]\\*\\?-->\\[ \\\\t\\]\\*/g, ''\\)\\.replace\\(/\\\\n\\{3,\\}/g, '\\\\n\\\\n'\\);\nfs\\.writeFileSync\\(path, c, 'utf8'\\);\nconsole\\.log\\('Done:', count, 'comments removed'\\);\n\"$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "py": true,
        "dotnet build": true,
        "dotnet run": true,
        "/^powershell -Command \"foreach \\(\\$f in @\\('Resources\\\\Prototypes\\\\_Nuclear14\\\\Roles\\\\Jobs\\\\NCR\\\\ncr_cadet\\.yml','Resources\\\\Prototypes\\\\_Nuclear14\\\\Roles\\\\Jobs\\\\NCR\\\\ncr_sgt\\.yml','Resources\\\\Prototypes\\\\_Nuclear14\\\\Roles\\\\Jobs\\\\NCR\\\\ncr_lt\\.yml','Resources\\\\Prototypes\\\\_Nuclear14\\\\Roles\\\\Jobs\\\\NCR\\\\ncr_medic\\.yml','Resources\\\\Prototypes\\\\_Nuclear14\\\\Roles\\\\Jobs\\\\NCR\\\\ncr_engineer\\.yml'\\)\\) \\{ \\$lines = Get-Content \\$f; \\$header = '#Misfits Change - commented out, moved to _Misfits'; \\$commented = @\\(\\$header\\) \\+ \\(\\$lines \\| ForEach-Object \\{ '#' \\+ \\$_ \\}\\); Set-Content \\$f -Value \\$commented -NoNewline:\\$false; Write-Host \\('Commented: ' \\+ \\$f\\) \\}\"$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^node -e \"\nconst fs=require\\('fs'\\);\nconst path=require\\('path'\\);\nconst B='h:/nuclear-14-PR/nuclear-14/Resources/Prototypes';\nconst N14=B\\+'/_Nuclear14/Roles/Jobs/NCR';\nconst COV=B\\+'/Corvax/Roles/Jobs/NCR';\nconst files=\\[\n  \\[N14\\+'/captain\\.yml',          '# Moved to: _Misfits/Roles/Jobs/NCR/ncr_captain\\.yml'\\],\n  \\[N14\\+'/lieutenant\\.yml',       '# Moved to: _Misfits/Roles/Jobs/NCR/ncr_lieutenant\\.yml'\\],\n  \\[N14\\+'/doctor\\.yml',           '# Moved to: _Misfits/Roles/Jobs/NCR/ncr_doctor\\.yml'\\],\n  \\[N14\\+'/first_sergeant\\.yml',   '# Moved to: _Misfits/Roles/Jobs/NCR/ncr_first_sergeant\\.yml'\\],\n  \\[N14\\+'/staff_sergeant\\.yml',   '# Moved to: _Misfits/Roles/Jobs/NCR/ncr_staff_sergeant\\.yml'\\],\n  \\[N14\\+'/sergeant\\.yml',         '# Moved to: _Misfits/Roles/Jobs/NCR/ncr_sergeant\\.yml'\\],\n  \\[N14\\+'/corporal\\.yml',         '# Moved to: _Misfits/Roles/Jobs/NCR/ncr_corporal\\.yml'\\],\n  \\[N14\\+'/medic\\.yml',            '# Moved to: _Misfits/Roles/Jobs/NCR/ncr_medic\\.yml'\\],\n  \\[N14\\+'/engineer\\.yml',         '# Moved to: _Misfits/Roles/Jobs/NCR/ncr_engineer\\.yml'\\],\n  \\[N14\\+'/private_first_class\\.yml','# Moved to: _Misfits/Roles/Jobs/NCR/ncr_private_first_class\\.yml'\\],\n  \\[N14\\+'/private\\.yml',          '# Moved to: _Misfits/Roles/Jobs/NCR/ncr_private\\.yml'\\],\n  \\[N14\\+'/recruit\\.yml',          '# Moved to: _Misfits/Roles/Jobs/NCR/ncr_recruit\\.yml'\\],\n  \\[COV\\+'/mp_investigator\\.yml',  '# Moved to: _Misfits/Roles/Jobs/NCR/ncr_mp_investigator\\.yml'\\],\n\\];\nfor\\(const \\[p,h\\] of files\\)\\{\n  const content=fs\\.readFileSync\\(p,'utf8'\\);\n  const commented=h\\+'\\\\n'\\+content\\.split\\('\\\\n'\\)\\.map\\(l=>'# '\\+l\\)\\.join\\('\\\\n'\\)\\+'\\\\n';\n  fs\\.writeFileSync\\(p,commented\\);\n  console\\.log\\('OK:',path\\.basename\\(p\\)\\);\n\\}\n// Prisoner\\.yml - already commented out, just update header\nconst prisonerPath=COV\\+'/Prisoner\\.yml';\nconst raw=fs\\.readFileSync\\(prisonerPath,'utf8'\\);\nconst updated=raw\\.replace\\(/\\^# Renamed to:\\.\\*/, '# Moved to: _Misfits/Roles/Jobs/NCR/ncr_prisoner\\.yml'\\);\nfs\\.writeFileSync\\(prisonerPath, updated\\);\nconsole\\.log\\('OK: Prisoner\\.yml \\(header updated\\)'\\);\n\"\n$/": {
            "approve": true,
            "matchCommandLine": true
        }
    }
}
