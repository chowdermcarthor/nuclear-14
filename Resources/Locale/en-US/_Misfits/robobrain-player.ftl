## Robobrain player chassis locale strings.
## Used by the RobobrainAcidifySystem and related UI.

# Emote broadcast to nearby players — entity name is prefixed automatically by the emote system
robobrain-acidify-warning = emits a low gurgling hiss as fluid begins flooding its cranial cavity.

# Private message sent only to the player being ejected
robobrain-acidify-self = Your consciousness dissolves into the void as acid claims your brain...

## Sentry Bot locale strings.
## Used by the SentryBotOverheatSystem and SentryBotMissileLauncherSystem.

# Overheat popup shown when main weapon ammo depletes
sentrybot-overheat-warning = PURGING FUSION CORE OVERHEAT

# Systems restored popup shown when overheat cooldown ends
sentrybot-systems-nominal = SYSTEMS NOMINAL — WEAPON ONLINE

# Missile lock warning shown to entities near the targeted location
sentrybot-missile-lock-warning = MISSILE LOCK DETECTED — INCOMING!
